package org.example;

import javax.swing.*;

public class Main extends JFrame {

    public Main() {

        setTitle("Final Project Grafika Komputer");
        setSize(900,600);
        setLocationRelativeTo(null);
        setDefaultCloseOperation(EXIT_ON_CLOSE);

        JTabbedPane tab = new JTabbedPane();

        tab.addTab("Color Space", new ColorSpacePanel());
        tab.addTab("Translasi", new TranslasiPanel());
        tab.addTab("Line DDA", new DDAPanel());

        add(tab);

        setVisible(true);
    }

    public static void main(String[] args) {
        SwingUtilities.invokeLater(() -> new Main());
    }
}
